{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "gestion-couture",
  "version": "0.1.0",
  "identifier": "com.gestion-couture.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Gestion Couture",
        "width": 1280,
        "height": 720,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "icon": ["icons/icon.ico"],
    "externalBin": ["bin/backend"]
  }
}