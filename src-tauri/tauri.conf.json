{
  "productName": "gestion-couture",

  "version": "0.1.0",

  "identifier": "com.gestion.couture.desktop",

  "build": {

    "frontendDist": "../dist",

    "devUrl": "http://localhost:1420",

    "beforeDevCommand": "npm run dev",

    "beforeBuildCommand": "npm run build"
  },

  "app": {

    "windows": [
      {
        "title": "Gestion Couture",

        "width": 1200,

        "height": 800,

        "resizable": true,

        "fullscreen": false
      }
    ],

    "security": {
      "csp": null
    }
  },

  "plugins": {

    "shell": {
      "open": true
    }
  },

  "bundle": {

    "active": true,

    "targets": ["nsis"],

    "icon": [

      "icons/32x32.png",

      "icons/128x128.png",

      "icons/128x128@2x.png",

      "icons/icon.icns",

      "icons/icon.ico"
    ]
  }
}