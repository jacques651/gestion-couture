{
  "$schema": "../gen/schemas/desktop-schema.json",

  "identifier": "default",

  "description": "Capability for the main window",

  "windows": ["main"],

  "permissions": [

    "core:default",

    "opener:default",

    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-save",

    "fs:default",
    "fs:allow-appdata-read",
    "fs:allow-appdata-write",
    "fs:allow-appdata-meta",
    "fs:allow-read-file",
    "fs:allow-write-file",
    "fs:allow-mkdir",
    "fs:allow-exists",
    "fs:allow-copy-file",
    "fs:allow-rename",
    "fs:allow-remove",
    "fs:allow-stat",

    "shell:default",
    "shell:allow-spawn",

    "log:default"
  ]
}