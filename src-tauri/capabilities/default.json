{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",

    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-save",

    "fs:default",
    "fs:allow-read",
    "fs:allow-write",
    "fs:write-all",
    "fs:read-all",

    "sql:default",
    "sql:allow-load",
    "sql:allow-execute",
    "sql:allow-select",

    "log:default"
  ]
}